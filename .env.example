# ---------------------------------------------------------------------------
# SBOM Visualizer — environment template.
# Copy to `.env` (`cp .env.example .env`) and adjust as needed.
# Compose reads `.env` automatically; the `api` service loads it via env_file.
# ---------------------------------------------------------------------------

# ---- Host port mapping (web service) --------------------------------------
# Ports published on the host. 80/443 are the defaults; change if those are
# taken (e.g. HTTP_PORT=8080 HTTPS_PORT=8443 -> visit https://localhost:8443).
HTTP_PORT=80
HTTPS_PORT=443

# ---- TLS certificate paths (informational) --------------------------------
# The web container always reads these two files (mounted at /etc/nginx/certs):
#   certs/fullchain.pem  and  certs/privkey.pem
# Generate self-signed ones with `make certs`. Override the self-signed
# subject/SANs at generation time:
#   CN=sbom.example.com
#   EXTRA_SAN=DNS:sbom.example.com,IP:127.0.0.1
#   CERT_DAYS=825

# ---- Backend tunables (consumed by ./backend) -----------------------------
# These are passed through to the FastAPI app. Names mirror the backend's
# expected settings; safe defaults shown. Adjust to taste.

# Upstream HTTP timeouts (seconds) for external enrichment calls
# (OSV.dev, cve.org, CISA KEV, FIRST EPSS).
UPSTREAM_TIMEOUT=20
UPSTREAM_CONNECT_TIMEOUT=10

# Max concurrent in-flight external requests (vuln detail hydration).
SCAN_CONCURRENCY=10

# Abort a scan after this many upstream errors (error-threshold guard).
SCAN_ERROR_THRESHOLD=25

# Server-side response cache (PURL/CVE keyed) time-to-live, seconds.
CACHE_TTL=3600

# Default shippability policy when the client doesn't specify one.
# strict | standard | lenient
DEFAULT_POLICY=standard

# Uvicorn log level: critical | error | warning | info | debug | trace
# (Also drives the feeds service log level: DEBUG/INFO/WARNING/ERROR.)
LOG_LEVEL=info

# ---- Local vulnerability mirror (feeds service) ---------------------------
# The internal `feeds` service mirrors KEV/EPSS/NVD locally and serves them to
# the api over the private network. The api uses the mirror when USE_FEEDS=true,
# falling back to live upstreams until the mirror has populated.
USE_FEEDS=true

# Daily wholesale-refresh time (24h HH:MM, service-local time).
FEEDS_DAILY_AT=03:15

# NVD API key (optional). Uncomment + set to raise the NVD mirror refresh rate
# (50 vs 5 requests / 30s), which dramatically speeds up the full crawl.
#NVD_API_KEY=

# First-run NVD page cap (0 = full inventory). Set to e.g. 2 for a fast first
# boot / demo; leave 0 in production to mirror the complete CVE inventory.
NVD_INITIAL_MAX_PAGES=0

# ---- Offline OSV mirror (feeds writes, api scans) -------------------------
# The feeds scheduler also mirrors the FULL OSV database into the shared
# `osv-db` volume (at OSV_CACHE_DIR), and the api runs the bundled osv-scanner
# binary against it in offline mode for vulnerability discovery.
#
# NOTE: the OSV mirror is ~1.2GB (all 45 ecosystems) and is downloaded daily by
# the feeds scheduler. The first populate takes several minutes; until it is
# ready the api uses live OSV (api.osv.dev) as a fallback automatically.
USE_OFFLINE_OSV=true

# Shared cache dir for the OSV mirror (the `osv-db` volume mount point). The api
# also sets XDG_CACHE_HOME to this so osv-scanner finds <eco>/all.zip under it.
OSV_CACHE_DIR=/osv-cache
ENABLE_MITRE=false

